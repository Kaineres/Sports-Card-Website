    {
      "id": "cgc_certlookup_cgc_cert_verification",
      "label": "CGC Card Certification Verification",
      "file_type": "rationale",
      "source_file": "docs/cards/raw/verify-card-certification-look-up-a-cgc-certification-number-202605200056.md",
      "source_location": null,
      "source_url": "https://www.cgccards.com/certlookup/6031819005",
      "captured_at": "2026-05-20",
      "author": null,
      "contributor": null,
      "rationale": "CGC provides a public cert lookup tool (certlookup/) where any certification number can be verified. The lookup returns card name, game, year, language, set, card number, variant, grade, grader notes, obverse/reverse images, and population breakdown (cards at same grade vs higher grades). This is the anti-counterfeiting and trust layer for the secondary market."
    },
    {
      "id": "cgc_certlookup_cgc_guarantee",
      "label": "CGC Guarantee",
      "file_type": "rationale",
      "source_file": "docs/cards/raw/verify-card-certification-look-up-a-cgc-certification-number-202605200056.md",
      "source_location": null,
      "source_url": "https://www.cgccards.com/certlookup/6031819005",
      "captured_at": "2026-05-20",
      "author": null,
      "contributor": null,
      "rationale": "Every CGC-certified card is backed by the CGC Guarantee, providing protection for buyers and sellers. This is CGC's market trust mechanism, distinguishing their slabs from ungraded or competitor-graded cards."
    },

    {
      "id": "pop_count_high_pop_strategy",
      "label": "High POP Count Investment Strategy",
      "file_type": "rationale",
      "source_file": "docs/cards/raw/Sports Card Investing Population Count Explained and What it Means to You.md",
      "source_location": null,
      "source_url": "https://sports.yahoo.com/sports-card-investing-population-count-155709943.html",
      "captured_at": "2026-05-19",
      "author": "Chris Gawlik",
      "contributor": "Dan Devine",
      "rationale": "High POP count cards trade frequently on eBay, enabling easy price discovery by averaging last 3-5 sales. Sellers face competition and may accept 80-90% of comps. Buyers benefit from supply availability."
    },
    {
      "id": "pop_count_low_pop_strategy",
      "label": "Low POP Count Investment Strategy",
      "file_type": "rationale",
      "source_file": "docs/cards/raw/Sports Card Investing Population Count Explained and What it Means to You.md",
      "source_location": null,
      "source_url": "https://sports.yahoo.com/sports-card-investing-population-count-155709943.html",
      "captured_at": "2026-05-19",
      "author": "Chris Gawlik",
      "contributor": "Dan Devine",
      "rationale": "Low POP count cards allow sellers to set their own price due to sparse comparable sales and limited availability. Seller holds pricing power: 'Yesterday's price is not today's price.'"
    },

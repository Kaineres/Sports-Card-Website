    {
      "id": "sgc_grading_scale_no_tweeners_principle",
      "label": "SGC No-Tweeners Grading Principle",
      "file_type": "rationale",
      "source_file": "docs/cards/raw/SGC Grading Scale.md",
      "source_location": null,
      "source_url": "https://www.gosgc.com/card-grading/scale",
      "captured_at": "2026-05-18",
      "author": null,
      "contributor": null,
      "rationale": "SGC's scale is designed to eliminate 'tweener' grades — ambiguous in-between values — producing a more precise and consistent grading output, which in turn supports more accurate market pricing for cards."
    },

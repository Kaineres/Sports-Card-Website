    {
      "id": "pop_count_pop_count_concept",
      "label": "Population Count (POP Count)",
      "file_type": "rationale",
      "source_file": "docs/cards/raw/Sports Card Investing Population Count Explained and What it Means to You.md",
      "source_location": null,
      "source_url": "https://sports.yahoo.com/sports-card-investing-population-count-155709943.html",
      "captured_at": "2026-05-19",
      "author": "Chris Gawlik",
      "contributor": "Dan Devine",
      "rationale": "POP count is the number of graded cards with the same score at a given grade level. It represents market supply competition for sellers and pricing leverage for buyers. High POP = easy to price and sell quickly, but competitive. Low POP = seller controls pricing, less comparable sales."
    },
